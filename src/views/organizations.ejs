<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Here are a few of our partner organizations:</p>
    <ul class="organizations-list">
        <% organizations.forEach((organization) => { %>
            <li class="org-card">
                <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                <strong><%= organization.name %></strong>
                <p><%= organization.description %></p>
                <p><a href="mailto:<%= organization.contact_email %>"><%= organization.contact_email %></a></p>
            </li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>